# HyperClaw .env example
#
# Quick start:
# 1) Copy to `.env` (local) or `~/.hyperclaw/.env` (daemon).
# 2) Fill only what you use.
# 3) Keep secrets out of git.
#
# Precedence: process env → ./.env → ~/.hyperclaw/.env; config keys (hyperclaw.json)
# often take precedence over env fallbacks.

# -----------------------------------------------------------------------------
# Gateway auth + paths
# -----------------------------------------------------------------------------
# Env fallback when gateway.authToken is unset in hyperclaw.json:
# HYPERCLAW_GATEWAY_TOKEN=change-me

# Path overrides (wired in code):
# HYPERCLAW_STATE_DIR=~/.hyperclaw
# HYPERCLAW_CONFIG_PATH=~/.hyperclaw/hyperclaw.json
# HYPERCLAW_HOME=~

# -----------------------------------------------------------------------------
# Model provider API keys (set at least one)
# -----------------------------------------------------------------------------
# Env fallback used by gateway + runner when provider.apiKey is unset:
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=

# For openai/xai/google providers, set apiKey via `hyperclaw config set-key`
# or store in .env — secrets audit knows these:
# OPENAI_API_KEY=
# XAI_API_KEY=
# GOOGLE_AI_API_KEY=

# -----------------------------------------------------------------------------
# Channels
# -----------------------------------------------------------------------------
# Channel tokens usually in hyperclaw.json (channels.telegram.botToken etc.).
# These are known by secrets audit; env fallback depends on connector:
# TELEGRAM_BOT_TOKEN=
# DISCORD_BOT_TOKEN=
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_SIGNING_SECRET=   # for Events API webhook verification

# -----------------------------------------------------------------------------
# Skills (plugins read from process.env / .env)
# -----------------------------------------------------------------------------
# TAVILY_API_KEY=           # web-search
# DEEPL_API_KEY=            # translator
# OPENWEATHER_API_KEY=      # weather
# GITHUB_TOKEN=             # github
# BRAVE_API_KEY=            # MCP Brave search
# GOOGLE_CALENDAR_CREDS=    # calendar
# DATABASE_URL=             # db-reader
# HA_URL=                   # home-assistant
# HA_TOKEN=

# -----------------------------------------------------------------------------
# Talk Mode (ElevenLabs TTS)
# -----------------------------------------------------------------------------
# ELEVENLABS_API_KEY=   # for Talk Mode — voice responses

# -----------------------------------------------------------------------------
# Other
# -----------------------------------------------------------------------------
# NODE_ENV=production
# NIX_STORE=                # set by Nix; affects install detection
# HC_PORT=                  # set by daemon; don't set manually
