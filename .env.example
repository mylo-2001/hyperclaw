# HyperClaw — environment variables template
# ─────────────────────────────────────────────────────────────────────────────
# HOW TO USE:
#   cp .env.example ~/.hyperclaw/.env
#   Fill in only the keys you need — leave the rest blank or delete them.
#   NEVER commit your actual .env file to git.
#
# Precedence: process env → ./.env → ~/.hyperclaw/.env → hyperclaw.json
# ─────────────────────────────────────────────────────────────────────────────

# ══════════════════════════════════════════════════════════════════════════════
# AI PROVIDERS  (set at least one)
# ══════════════════════════════════════════════════════════════════════════════

# Anthropic — Claude (claude-opus-4-5, claude-sonnet-4-5, claude-haiku-4-5)
# Get key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# OpenAI — GPT-4o, GPT-4.1, o3, o4-mini + DALL-E 3 image generation
# Get key: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Google — Gemini 2.5 Pro, Gemini 2.0 Flash
# Get key: https://aistudio.google.com/app/apikey
GOOGLE_AI_API_KEY=

# xAI — Grok 3
# Get key: https://console.x.ai/
XAI_API_KEY=

# OpenRouter — 200+ models with one key (Claude, GPT, Gemini, Llama…)
# Get key: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Groq — Llama, Mixtral (very fast inference)
# Get key: https://console.groq.com/keys
GROQ_API_KEY=

# Mistral AI
# Get key: https://console.mistral.ai/api-keys
MISTRAL_API_KEY=

# DeepSeek
# Get key: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# Perplexity (search-augmented AI)
# Get key: https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=

# HuggingFace Inference API
# Get key: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=

# MiniMax
# Get key: https://www.minimaxi.com/user-center/basic-information/interface-key
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=

# Moonshot (Kimi)
# Get key: https://platform.moonshot.cn/user-center/api-keys
MOONSHOT_API_KEY=

# Qwen (Alibaba Cloud)
# Get key: https://dashscope.aliyun.com/
QWEN_API_KEY=

# Z.AI (GLM)
# Get key: https://open.bigmodel.cn/usercenter/apikeys
ZAI_API_KEY=

# LiteLLM proxy — OpenAI-compatible, self-hosted
LITELLM_BASE_URL=http://localhost:4000
LITELLM_API_KEY=

# Cloudflare AI Gateway
# Get: https://dash.cloudflare.com → AI → AI Gateway
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_AI_TOKEN=

# Vercel AI Gateway
VERCEL_AI_TOKEN=

# Ollama (local models — no key needed, just set URL if non-default)
OLLAMA_BASE_URL=http://localhost:11434

# LM Studio (local models — no key needed, just set URL if non-default)
LM_STUDIO_BASE_URL=http://localhost:1234

# Custom OpenAI-compatible API
CUSTOM_AI_BASE_URL=
CUSTOM_AI_API_KEY=

# ══════════════════════════════════════════════════════════════════════════════
# CHAT CHANNELS
# ══════════════════════════════════════════════════════════════════════════════

# ── Telegram ──────────────────────────────────────────────────────────────────
# Get token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# ── Discord ───────────────────────────────────────────────────────────────────
# https://discord.com/developers/applications → Bot → Token
DISCORD_TOKEN=

# ── Slack ─────────────────────────────────────────────────────────────────────
# https://api.slack.com/apps → OAuth & Permissions
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_SIGNING_SECRET=

# ── WhatsApp (Meta Cloud API) ─────────────────────────────────────────────────
# https://developers.facebook.com/ → WhatsApp → API Setup
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=

# ── WhatsApp (Baileys — unofficial, no Meta account needed) ───────────────────
# No token needed — scans QR code on first run. Set SESSION_DIR if needed.
WHATSAPP_BAILEYS_SESSION_DIR=

# ── Twitch ────────────────────────────────────────────────────────────────────
# Generate OAuth token: https://twitchapps.com/tmi/
TWITCH_BOT_USERNAME=
TWITCH_OAUTH_TOKEN=
TWITCH_CHANNELS=

# ── Signal ────────────────────────────────────────────────────────────────────
# Requires signal-cli: https://github.com/AsamK/signal-cli
SIGNAL_PHONE_NUMBER=
SIGNAL_CLI_PATH=

# ── Matrix ────────────────────────────────────────────────────────────────────
# Create a bot account on your Matrix homeserver
MATRIX_HOMESERVER_URL=https://matrix.org
MATRIX_ACCESS_TOKEN=
MATRIX_USER_ID=

# ── IRC ───────────────────────────────────────────────────────────────────────
IRC_SERVER=irc.libera.chat
IRC_PORT=6697
IRC_NICK=
IRC_PASSWORD=
IRC_CHANNELS=

# ── Mattermost ────────────────────────────────────────────────────────────────
# https://your-mattermost.com → Profile → Security → Personal Access Tokens
MATTERMOST_URL=
MATTERMOST_TOKEN=
MATTERMOST_TEAM=

# ── Microsoft Teams ───────────────────────────────────────────────────────────
# https://portal.azure.com → App registrations
MSTEAMS_APP_ID=
MSTEAMS_APP_PASSWORD=
MSTEAMS_TENANT_ID=

# ── Google Chat ───────────────────────────────────────────────────────────────
# https://console.cloud.google.com → Google Chat API
GOOGLE_CHAT_CREDENTIALS_PATH=
GOOGLE_CHAT_PROJECT_ID=

# ── Nextcloud Talk ────────────────────────────────────────────────────────────
NEXTCLOUD_URL=
NEXTCLOUD_USERNAME=
NEXTCLOUD_PASSWORD=

# ── Synology Chat ─────────────────────────────────────────────────────────────
# Synology DSM → Chat → Integrations → Incoming webhook
SYNOLOGY_CHAT_URL=
SYNOLOGY_CHAT_TOKEN=

# ── Feishu / Lark ─────────────────────────────────────────────────────────────
# https://open.feishu.cn/app
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=

# ── Zalo ──────────────────────────────────────────────────────────────────────
# https://developers.zalo.me/
ZALO_APP_ID=
ZALO_APP_SECRET=
ZALO_ACCESS_TOKEN=

# ── Line ──────────────────────────────────────────────────────────────────────
# https://developers.line.biz/console/
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# ── Nostr ─────────────────────────────────────────────────────────────────────
# Generate a keypair with: npx nostr-keygen
NOSTR_PRIVATE_KEY=
NOSTR_RELAYS=wss://relay.damus.io,wss://nos.lol

# ── Tlon (Urbit Groups) ───────────────────────────────────────────────────────
# Your Urbit ship URL and code from web.browser
TLON_SHIP_URL=http://localhost:8080
TLON_SHIP_CODE=
TLON_GROUP=~sampel-palnet/your-group

# ── BlueBubbles (iMessage on non-Mac) ────────────────────────────────────────
# https://bluebubbles.app — requires a Mac running BlueBubbles server
BLUEBUBBLES_SERVER_URL=
BLUEBUBBLES_PASSWORD=

# ── iMessage (macOS native) ───────────────────────────────────────────────────
# No key needed — macOS only, requires Full Disk Access + Accessibility permissions

# ══════════════════════════════════════════════════════════════════════════════
# WEB SEARCH
# ══════════════════════════════════════════════════════════════════════════════

# Tavily — best for AI agents: https://app.tavily.com/
TAVILY_API_KEY=

# Brave Search: https://api.search.brave.com/
BRAVE_API_KEY=

# Perplexity (also used as search): already set above under AI Providers

# Kimi / Moonshot search: already set above under AI Providers

# ══════════════════════════════════════════════════════════════════════════════
# CORE TOOLS & INTEGRATIONS
# ══════════════════════════════════════════════════════════════════════════════

# ── Image Generation ──────────────────────────────────────────────────────────
# OpenAI DALL-E 3: already set above (OPENAI_API_KEY)
# Stability AI: https://platform.stability.ai/account/keys
STABILITY_API_KEY=

# ── GIF Search ────────────────────────────────────────────────────────────────
# Giphy: https://developers.giphy.com
GIPHY_API_KEY=
# Tenor (Google): https://console.cloud.google.com → Tenor API
TENOR_API_KEY=

# ── GitHub ────────────────────────────────────────────────────────────────────
# https://github.com/settings/tokens (select repo, read:user, read:org)
GITHUB_TOKEN=

# ── Home Assistant ────────────────────────────────────────────────────────────
# Profile → Long-lived access tokens
HA_URL=
HA_TOKEN=

# ── Gmail / Google OAuth ──────────────────────────────────────────────────────
# https://console.cloud.google.com → APIs & Services → OAuth 2.0 Client ID
GOOGLE_CREDENTIALS_PATH=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GMAIL_PUBSUB_TOPIC=

# ── Google Calendar ───────────────────────────────────────────────────────────
# Uses same GOOGLE_CREDENTIALS_PATH as Gmail above
GOOGLE_CALENDAR_CREDS=

# ══════════════════════════════════════════════════════════════════════════════
# PRODUCTIVITY TOOLS
# ══════════════════════════════════════════════════════════════════════════════

# Trello — https://trello.com/app-key
TRELLO_API_KEY=
TRELLO_TOKEN=

# Obsidian — install "Local REST API" plugin in Obsidian
OBSIDIAN_API_KEY=
OBSIDIAN_PORT=27123

# Apple Notes / Reminders / Things 3 / Bear Notes
# macOS only — no key needed, requires Accessibility permissions

# ══════════════════════════════════════════════════════════════════════════════
# MUSIC
# ══════════════════════════════════════════════════════════════════════════════

# Spotify — https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REFRESH_TOKEN=

# Sonos — local IP of your speaker (no account needed)
SONOS_IP=

# Music search — free, no key needed (iTunes Search API)

# ══════════════════════════════════════════════════════════════════════════════
# SMART HOME
# ══════════════════════════════════════════════════════════════════════════════

# Philips Hue — bridge IP + username from bridge pairing
# Bridge pairing: http://<BRIDGE_IP>/debug/clip.html
HUE_BRIDGE_IP=
HUE_USERNAME=

# 8Sleep
EIGHTSLEEP_EMAIL=
EIGHTSLEEP_PASSWORD=

# ══════════════════════════════════════════════════════════════════════════════
# SECURITY & MESSAGING
# ══════════════════════════════════════════════════════════════════════════════

# 1Password — https://my.1password.com → Integrations → Service Accounts
OP_SERVICE_ACCOUNT_TOKEN=

# ══════════════════════════════════════════════════════════════════════════════
# VOICE (Talk Mode)
# ══════════════════════════════════════════════════════════════════════════════

# ElevenLabs — Text-to-Speech
# Get key: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# ══════════════════════════════════════════════════════════════════════════════
# TRANSLATION
# ══════════════════════════════════════════════════════════════════════════════

# DeepL — https://www.deepl.com/pro-api
DEEPL_API_KEY=

# ══════════════════════════════════════════════════════════════════════════════
# BUG BOUNTY / OSINT
# ══════════════════════════════════════════════════════════════════════════════

# HackerOne API — https://api.hackerone.com/
HACKERONE_API_USERNAME=
HACKERONE_API_TOKEN=

# Bugcrowd API
BUGCROWD_API_TOKEN=

# Synack
SYNACK_API_KEY=

# ══════════════════════════════════════════════════════════════════════════════
# GATEWAY & SYSTEM
# ══════════════════════════════════════════════════════════════════════════════

# Gateway auth token (leave blank to auto-generate on first run)
HYPERCLAW_GATEWAY_TOKEN=

# Override gateway port (default: 18789)
HYPERCLAW_PORT=18789

# State directory override (default: ~/.hyperclaw)
HYPERCLAW_STATE_DIR=
