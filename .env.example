# HyperClaw — environment variables template
# ─────────────────────────────────────────────────────────────────────────────
# HOW TO USE:
#   cp .env.example ~/.hyperclaw/.env
#   Then fill in only the keys you need — leave the rest blank.
#   NEVER commit your actual .env file to git.
#
# Precedence: process env → ./.env → ~/.hyperclaw/.env → hyperclaw.json
# ─────────────────────────────────────────────────────────────────────────────

# ── AI Providers (set at least one) ──────────────────────────────────────────

# Anthropic — Claude (claude-opus-4-5, claude-sonnet-4-5, claude-haiku-4-5)
# Get key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# OpenAI — GPT-4o, GPT-4.1, DALL-E 3 image generation
# Get key: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# xAI — Grok
# Get key: https://console.x.ai/
XAI_API_KEY=

# OpenRouter — 200+ models with one key (Claude, GPT, Gemini, Llama…)
# Get key: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Groq — Llama, Mixtral (very fast inference)
# Get key: https://console.groq.com/keys
GROQ_API_KEY=

# Mistral AI
# Get key: https://console.mistral.ai/api-keys
MISTRAL_API_KEY=

# DeepSeek
# Get key: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# Perplexity
# Get key: https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=

# HuggingFace Inference API
# Get key: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=

# Ollama / LM Studio (local models — no key needed, just set the URL)
OLLAMA_BASE_URL=http://localhost:11434
LM_STUDIO_BASE_URL=http://localhost:1234

# ── Chat Channels ─────────────────────────────────────────────────────────────

# Telegram — get token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Discord — https://discord.com/developers/applications
DISCORD_TOKEN=

# Slack — https://api.slack.com/apps → OAuth & Permissions
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=

# WhatsApp (Meta Cloud API) — https://developers.facebook.com/
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Twitch — generate an IRC OAuth token for your bot account
TWITCH_BOT_USERNAME=
TWITCH_OAUTH_TOKEN=
TWITCH_CHANNELS=

# ── Web Search ────────────────────────────────────────────────────────────────

# Tavily — best for AI agents: https://app.tavily.com/
TAVILY_API_KEY=

# Brave Search: https://api.search.brave.com/
BRAVE_API_KEY=

# ── Core Tools ────────────────────────────────────────────────────────────────

# Image generation — Stability AI (alternative to DALL-E 3)
# Get key: https://platform.stability.ai/account/keys
STABILITY_API_KEY=

# GIF search — Giphy: https://developers.giphy.com
GIPHY_API_KEY=

# GIF search — Tenor (Google): https://console.cloud.google.com → Tenor API
TENOR_API_KEY=

# GitHub — for GitHub integration tools
# Get token: https://github.com/settings/tokens
GITHUB_TOKEN=

# Home Assistant
# Get token: Home Assistant → Profile → Long-lived access tokens
HA_URL=
HA_TOKEN=

# Gmail / Google OAuth
# Get credentials: https://console.cloud.google.com → APIs & Services → OAuth 2.0
GOOGLE_CREDENTIALS_PATH=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GMAIL_PUBSUB_TOPIC=

# ── Productivity Tools ────────────────────────────────────────────────────────

# Trello — https://trello.com/app-key
TRELLO_API_KEY=
TRELLO_TOKEN=

# Obsidian — install Local REST API plugin in Obsidian
OBSIDIAN_API_KEY=
OBSIDIAN_PORT=27123

# ── Music ─────────────────────────────────────────────────────────────────────

# Spotify — https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REFRESH_TOKEN=

# Sonos — local IP of your speaker (no account needed)
SONOS_IP=

# ── Smart Home ────────────────────────────────────────────────────────────────

# Philips Hue — bridge IP + username from bridge pairing
HUE_BRIDGE_IP=
HUE_USERNAME=

# 8Sleep
EIGHTSLEEP_EMAIL=
EIGHTSLEEP_PASSWORD=

# ── Security & Messaging ──────────────────────────────────────────────────────

# 1Password — https://my.1password.com → Integrations → Service Accounts
OP_SERVICE_ACCOUNT_TOKEN=

# ── Voice (Talk Mode) ─────────────────────────────────────────────────────────

# ElevenLabs — Text-to-Speech
# Get key: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# ── Translation ───────────────────────────────────────────────────────────────

# DeepL
# Get key: https://www.deepl.com/pro-api
DEEPL_API_KEY=

# ── Bug Bounty / OSINT ────────────────────────────────────────────────────────

# HackerOne API — https://api.hackerone.com/
HACKERONE_API_USERNAME=
HACKERONE_API_TOKEN=

# Bugcrowd API
BUGCROWD_API_TOKEN=

# Synack
SYNACK_API_KEY=

# ── Gateway & System ──────────────────────────────────────────────────────────

# Gateway auth token (leave blank to auto-generate on first run)
HYPERCLAW_GATEWAY_TOKEN=

# Override gateway port (default: 18789)
HYPERCLAW_PORT=18789

# State directory override (default: ~/.hyperclaw)
HYPERCLAW_STATE_DIR=
