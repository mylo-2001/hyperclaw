# HyperClaw — environment variables template
# Copy this file to .env and fill in your keys:
#   cp env.example .env
#
# Keys you don't use can be left blank or deleted.
# NEVER commit your .env file to git.

# ─── AI Providers (pick at least one) ────────────────────────────────────────

# Anthropic — Claude (claude-opus-4-5, claude-sonnet-4-5, claude-haiku-4-5)
# Get key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI — GPT-4o, GPT-4.1
# Get key: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# xAI — Grok
# Get key: https://console.x.ai/
XAI_API_KEY=xai-...

# OpenRouter — 200+ models with one key (Claude, GPT, Gemini, Llama…)
# Get key: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...

# Groq — Llama, Mixtral (very fast inference)
# Get key: https://console.groq.com/keys
GROQ_API_KEY=gsk_...

# ─── Chat Channels ────────────────────────────────────────────────────────────

# Telegram — get token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=123456789:AAF...

# Discord — get token from https://discord.com/developers/applications
DISCORD_TOKEN=MTI...

# Slack — get from https://api.slack.com/apps → OAuth & Permissions
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...

# WhatsApp (Meta Cloud API) — from https://developers.facebook.com/
# Twitch — generate an IRC OAuth token for your bot account
TWITCH_BOT_USERNAME=openclaw
TWITCH_OAUTH_TOKEN=oauth:abc123...
TWITCH_CHANNELS=vevisk

WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# ─── Optional Tools & Services ───────────────────────────────────────────────

# ElevenLabs — Text-to-Speech voice
# Get key: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=sk_...
ELEVENLABS_VOICE_ID=

# Tavily — web search for the agent
# Get key: https://app.tavily.com/
TAVILY_API_KEY=tvly-...

# GitHub — for GitHub integration tools
# Get token: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_...

# DeepL — translation
# Get key: https://www.deepl.com/pro-api
DEEPL_API_KEY=

# Google OAuth (Gmail, Google Calendar)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Stripe — billing (multi-tenant SaaS mode only)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Bug Bounty / OSINT ───────────────────────────────────────────────────────

# HackerOne API
HACKERONE_API_USERNAME=
HACKERONE_API_TOKEN=

# Bugcrowd API
BUGCROWD_API_TOKEN=

# Synack
SYNACK_API_KEY=

# ─── Gateway ─────────────────────────────────────────────────────────────────

# Override gateway port (default: 18789)
# HYPERCLAW_PORT=18789

# Auth token for the gateway REST API (leave blank to auto-generate)
# HYPERCLAW_GATEWAY_TOKEN=
